{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/:path*.(png|jpg|jpeg|webp|svg|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/:path*.(jsx|js|css|html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    }
  ]
}
